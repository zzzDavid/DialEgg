(include "base.egg")

;;;; Additional Type Definitions ;;;;
(function Int2 () Type)
(function Int3 () Type)
(function Int5 () Type)
(function Int6 () Type)
(function Int9 () Type)
(function Int10 () Type)
(function Int18 () Type)
(function Int128() Type)
(function Int256() Type)
(function Int384() Type)
(function Int512() Type)
(function Int2048 () Type)

;;;; comb dialect ;;;;
(function comb_mux (Op Op Op Type) Op)
(function comb_and (Op OpVec Type) Op)
(function comb_or (Op OpVec Type) Op)
(function comb_xor (Op OpVec Type) Op)
(function comb_replicate (Op Type) Op)
(function comb_concat (Op OpVec Type) Op)
(function comb_icmp (Op Op AttrPair Type) Op)
(function comb_extract (Op AttrPair Type) Op)
(function comb_add (Op OpVec Type) Op)
(function comb_sub (Op OpVec Type) Op)
(function comb_mul (Op Op Type) Op)

;;;; hw dialect ;;;;
(function hw_output (Op OpVec) Op)
(function hw_constant (AttrPair Type) Op)

;;;; seq dialect ;;;;
(function seq_to_clock (Op Type) Op)
(function seq_firreg (Op OpVec AttrPairVec Type) Op)
(function seq_clock_inv (Op Type) Op)

;;;; llhd dialect ;;;;
;; First-class declarations for the LLHD subset that CIRCT emits when
;; lowering procedural Verilog (`always` blocks with signal reads/drives).
;; llhd.process and llhd.wait still fall back to OpaqueOp because they
;; carry regions and variadic results that need richer encoding.
(function llhd_constant_time (AttrPair Type) Op)
(function llhd_sig (Op AttrPair Type) Op)
(function llhd_prb (Op Type) Op)
(function llhd_drv (Op Op Op Op) Op)
;; llhd.process / llhd.wait stay as OpaqueOp: they carry regions with
;; block arguments + successor edges (cf.br, cf.cond_br) that the egglog
;; region encoding doesn't model. Treating them as opaque keeps the
;; original MLIR op in place during reconstruction so the body survives
;; round-trip losslessly.

;;;; RootNode for extraction ;;;;
(datatype Root
  (RootNode Op)
)

;; OPS HERE ;;

;; RULES HERE ;;
(ruleset rules)

ASPEN_REWRITE_RULES

(run-schedule (saturate rules))

;; EXTRACTS HERE ;;
;; Shift operations
(function comb_shl (Op Op Type) Op)
(function comb_shru (Op Op Type) Op)
(function comb_shrs (Op Op Type) Op)
